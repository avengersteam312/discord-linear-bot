{
  "name": "discord-linear-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Discord slash-command bot that turns a thread into a Linear issue with OpenAI.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/avengersteam312/discord-linear-bot.git"
  },
  "bugs": {
    "url": "https://github.com/avengersteam312/discord-linear-bot/issues"
  },
  "homepage": "https://github.com/avengersteam312/discord-linear-bot#readme",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "check:setup": "tsx src/checkSetup.ts",
    "dev": "tsx watch src/index.ts",
    "register:commands": "tsx src/registerCommands.ts",
    "start": "node dist/index.js",
    "test": "npm run build && node --test test/*.test.js"
  },
  "dependencies": {
    "@linear/sdk": "^43.0.0",
    "discord.js": "^14.22.1",
    "dotenv": "^17.2.3",
    "openai": "^5.19.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
